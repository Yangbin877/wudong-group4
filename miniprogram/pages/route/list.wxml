<view class="page">
  <view style="font-size:36rpx;font-weight:bold;margin-bottom:20rpx;">路线套餐</view>
  <view style="display:flex;gap:12rpx;margin-bottom:20rpx;">
    <input style="flex:1;background:#fff;border-radius:12rpx;padding:16rpx 24rpx;font-size:28rpx;" placeholder="搜索路线" value="{{keyword}}" bindinput="onKeyword" bindconfirm="onSearch" />
    <button style="background:#e94560;color:#fff;font-size:28rpx;border-radius:12rpx;padding:16rpx 30rpx;" bindtap="onSearch">搜索</button>
  </view>
  <block wx:if="{{loading}}"><view class="loading">加载中...</view></block>
  <block wx:elif="{{list.length === 0}}"><view class="empty">暂无路线</view></block>
  <block wx:else>
    <navigator wx:for="{{list}}" wx:key="id" url="/pages/route/detail?id={{item.id}}" class="card">
      <view class="card-title">{{item.name}}</view>
      <view class="card-desc">{{item.description}}</view>
      <view class="card-extra">
        <text class="price">¥{{item.price}}</text>
        <text style="font-size:26rpx;color:#888;">{{item.days}}天</text>
      </view>
      <view wx:if="{{item.tags}}" style="display:flex;margin-top:12rpx;">
        <text wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag" class="tag">{{tag}}</text>
      </view>
    </navigator>
    <view style="display:flex;justify-content:center;gap:20rpx;margin-top:30rpx;">
      <button style="font-size:26rpx;" disabled="{{page <= 1}}" bindtap="prevPage">上一页</button>
      <text style="line-height:60rpx;font-size:26rpx;">第{{page}}页 / 共{{total}}条</text>
      <button style="font-size:26rpx;" disabled="{{page * pageSize >= total}}" bindtap="nextPage">下一页</button>
    </view>
  </block>
</view>
