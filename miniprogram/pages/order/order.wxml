<view class="page">
  <view wx:if="{{result}}">
    <view style="text-align:center;padding:80rpx 0;">
      <view style="font-size:100rpx;margin-bottom:20rpx;">✅</view>
      <view style="font-size:36rpx;font-weight:bold;margin-bottom:16rpx;">预订成功！</view>
      <view style="font-size:28rpx;color:#555;margin-bottom:8rpx;">订单号：{{result.orderNo}}</view>
      <view style="font-size:28rpx;color:#555;margin-bottom:8rpx;">二维码：{{result.qrCode}}</view>
      <view style="font-size:26rpx;color:#999;">有效日期：{{result.validStart || date}}</view>
      <navigator url="/pages/index/index" class="btn" style="margin-top:40rpx;">返回首页</navigator>
    </view>
  </view>

  <block wx:else>
    <view style="font-size:36rpx;font-weight:bold;margin-bottom:30rpx;">{{isRoute ? '预订路线套餐' : '预订门票'}}</view>
    <view class="card">
      <view style="margin-bottom:20rpx;">
        <view style="font-size:26rpx;color:#888;margin-bottom:8rpx;">游玩日期</view>
        <picker mode="date" value="{{date}}" bindchange="onDateChange">
          <view style="background:#f5f5f5;border-radius:12rpx;padding:16rpx 24rpx;font-size:28rpx;">{{date || '请选择日期'}}</view>
        </picker>
      </view>
      <view style="margin-bottom:20rpx;">
        <view style="font-size:26rpx;color:#888;margin-bottom:8rpx;">数量</view>
        <input style="background:#f5f5f5;border-radius:12rpx;padding:16rpx 24rpx;font-size:28rpx;" type="number" value="{{quantity}}" bindinput="onQty" />
      </view>
      <view style="margin-bottom:20rpx;">
        <view style="font-size:26rpx;color:#888;margin-bottom:8rpx;">联系手机</view>
        <input style="background:#f5f5f5;border-radius:12rpx;padding:16rpx 24rpx;font-size:28rpx;" type="number" value="{{phone}}" bindinput="onPhone" placeholder="请输入手机号" />
      </view>
    </view>
    <button class="btn" bindtap="onSubmit" disabled="{{submitting}}">{{submitting ? '提交中...' : '确认预订'}}</button>
  </block>
</view>
