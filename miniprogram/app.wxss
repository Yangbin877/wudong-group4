/** app.wxss **/
page { background: #f5f5f5; font-family: -apple-system, 'Microsoft YaHei', sans-serif; }
.page { padding: 20rpx; }
.card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,.04); }
.card-title { font-size: 32rpx; font-weight: bold; color: #1a1a2e; margin-bottom: 12rpx; }
.card-desc { font-size: 26rpx; color: #888; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }
.card-extra { display: flex; justify-content: space-between; align-items: center; margin-top: 16rpx; }
.price { color: #e94560; font-size: 36rpx; font-weight: bold; }
.tag { display: inline-block; background: #f0f0f0; border-radius: 8rpx; padding: 4rpx 16rpx; font-size: 22rpx; color: #666; margin-right: 10rpx; }
.btn { display: block; background: #e94560; color: #fff; text-align: center; border-radius: 12rpx; padding: 20rpx 0; font-size: 30rpx; margin: 20rpx 0; }
.btn:active { opacity: .8; }
.loading { text-align: center; padding: 100rpx 0; color: #999; font-size: 28rpx; }
.empty { text-align: center; padding: 100rpx 0; color: #999; font-size: 28rpx; }
